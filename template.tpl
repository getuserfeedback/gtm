- name: All consent types granted includes all scopes
  code: |-
    const queuedCommands = [];
    mock('createQueue', function(queueName) {
      return function(command) {
        queuedCommands.push(command);
      };
    });
    mock('isConsentGranted', function(consentType) {
      return true;
    });
    
    runCode({ apiKey: 'test123' });
    
    const initCommand = queuedCommands.filter(cmd => cmd.kind === 'init')[0];
    assertThat(initCommand).isDefined();
    assertThat(initCommand.opts.consent.scopes).isDefined();
    
    const scopes = initCommand.opts.consent.scopes;
    assertThat(scopes).contains('analytics.measurement');
    assertThat(scopes).contains('functionality.storage');
    assertThat(scopes).contains('security.storage');
    assertThat(scopes).contains('analytics.storage');
    assertThat(scopes).contains('personalization.storage');
    assertThat(scopes).contains('ads.storage');
    assertThat(scopes).contains('ads.user_data');
    assertThat(scopes).contains('ads.personalization');

