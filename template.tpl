- name: Manual mode mixed granted and GTM mappings
  code: |-
    const queuedCommands = [];
    mock('createQueue', function(queueName) {
      return function(command) {
        queuedCommands.push(command);
      };
    });
    mock('isConsentGranted', function(consentType) {
      return consentType === 'analytics_storage';
    });
    
    runCode({
      apiKey: 'test123',
      consentMode: 'manual',
      scopeMappings: [
        { scope: 'functionality.storage', mapping: 'granted' },
        { scope: 'analytics.storage', mapping: 'analytics_storage' },
        { scope: 'ads.storage', mapping: 'ad_storage' }
      ]
    });
    
    const initCommand = queuedCommands.filter(cmd => cmd.kind === 'init')[0];
    const scopes = initCommand.opts.consent.scopes;
    
    assertThat(scopes).contains('functionality.storage');
    assertThat(scopes).contains('analytics.storage');
    assertThat(scopes).doesNotContain('ads.storage');

