const log = require('logToConsole');
const injectScript = require('injectScript');
const queryPermission = require('queryPermission');
const createQueue = require('createQueue');
const callInWindow = require('callInWindow');
const isConsentGranted = require('isConsentGranted');

// Build the widget URL using the API key
const apiKey = data.apiKey;
const widgetUrl = 'https://cdn.getuserfeedback.com/widget/v1/' + apiKey + '/widget.js';

log('Loading getuserfeedback widget:', widgetUrl);

// Create the command queue for the widget
const queuePush = createQueue('__getuserfeedback_queue');

// Handle theme configuration based on mode
if (data.themeMode === 'variable') {
  // Dynamic mode - only queue if variable has a valid value
  const variableValue = data.themeModeVariable;
  
  // Check if variable value is valid (light, dark, or system only)
  if (variableValue === 'light' || variableValue === 'dark' || variableValue === 'system') {
    queuePush({
      kind: 'setColorScheme',
      scheme: variableValue
    });
    log('Queued setColorScheme from variable:', variableValue);
  } else {
    // Invalid or undefined - don't send anything, let widget use its defaults
    log('Variable value invalid or empty:', variableValue, '- skipping theme config');
}

} else if (data.themeMode === 'light' || data.themeMode === 'dark') {
  // Fixed theme mode - set the color scheme
  queuePush({
    kind: 'setColorScheme',
    scheme: data.themeMode
  });
  log('Queued setColorScheme (fixed):', data.themeMode);
  
} else if (data.themeMode === 'system') {
  // System preference mode
  queuePush({
    kind: 'setColorScheme',
    scheme: 'system'
  });
  log('Queued setColorScheme (system)');
  
} else if (data.themeMode === 'host') {
  // Host sync mode - only send if we have the required config
  // Only send themeAttr if it's defined
    if (data.themeAttr) {
      queuePush({
        kind: 'setThemeSourceAttr',
        attr: data.themeAttr
      });
      log('Queued setThemeSourceAttr:', data.themeAttr);
    }
    
  // Only send themeDefault if it's defined
    if (data.themeDefault) {
      queuePush({
        kind: 'setThemeDefault',
        theme: data.themeDefault
      });
      log('Queued setThemeDefault:', data.themeDefault);
    }
  
  // If neither is defined, nothing gets sent - widget uses its defaults
}

// =============================================================================
// Consent Configuration: Map GTM Consent Mode to Widget Scopes
// =============================================================================
// The widget uses a scope-based consent model that aligns with GTM Consent Mode.
// This section determines which scopes to grant based on user configuration.

const scopes = [];

if (data.consentMode === 'automatic') {
  // ---------------------------------------------------------------------------
  // AUTOMATIC MODE: Read GTM Consent Mode and auto-map to widget scopes
  // ---------------------------------------------------------------------------
  // Recommended for most users. Zero configuration needed.
  // Reads consent state from GTM's built-in Consent Mode API.
  
  // Always grant anonymous measurement (cookieless/anonymous analytics)
  // This allows basic telemetry without storage or persistent identifiers
  scopes.push('analytics.measurement');

  // Map each GTM consent type to its corresponding widget scope
  // Only add scopes when GTM consent is explicitly granted
  if (isConsentGranted('functionality_storage')) {
    scopes.push('functionality.storage');
  }
  if (isConsentGranted('security_storage')) {
    scopes.push('security.storage');
  }
  if (isConsentGranted('analytics_storage')) {
    scopes.push('analytics.storage');
  }
  if (isConsentGranted('personalization_storage')) {
    scopes.push('personalization.storage');
  }
  if (isConsentGranted('ad_storage')) {
    scopes.push('ads.storage');
  }
  if (isConsentGranted('ad_user_data')) {
    scopes.push('ads.user_data');
  }
  if (isConsentGranted('ad_personalization')) {
    scopes.push('ads.personalization');
  }
  
  log('GTM Consent Mode → Widget Scopes (automatic):', scopes);
  
} else if (data.consentMode === 'manual') {
  // ---------------------------------------------------------------------------
  // MANUAL MODE: Use custom scope mappings table
  // ---------------------------------------------------------------------------
  // For power users who need granular control or custom logic.
  // Each scope can be: always granted, always denied, or GTM consent-gated.
  
  const scopeMappings = data.scopeMappings || [];
  
  for (let i = 0; i < scopeMappings.length; i++) {
    const row = scopeMappings[i];
    const scope = row.scope;        // Widget scope (e.g., 'analytics.storage')
    const mapping = row.mapping;     // Condition (e.g., 'analytics_storage', 'granted', 'denied')
    
    if (mapping === 'granted') {
      // Unconditionally grant this scope (useful for testing/non-regulated sites)
      scopes.push(scope);
      
    } else if (mapping && mapping !== 'denied') {
      // Treat as GTM consent type - check if granted
      // Note: mapping can also be a GTM variable that resolves to a consent type or 'granted'/'denied'
      if (isConsentGranted(mapping)) {
        scopes.push(scope);
      }
    }
    // If 'denied' or undefined/empty: don't add the scope
  }
  
  log('Widget Scopes (manual):', scopes);
}

// Queue the consent configuration
queuePush({
  kind: 'init',
  opts: {
    consent: { scopes: scopes }
  }
});

// Inject the widget script
const onSuccess = function() {
  log('getuserfeedback widget loaded successfully');
data.gtmOnSuccess();
};

const onFailure = function() {
  log('Failed to load getuserfeedback widget');
  data.gtmOnFailure();
};

// Check if we have permission to inject the script
if (queryPermission('inject_script', widgetUrl)) {
  injectScript(widgetUrl, onSuccess, onFailure, 'getuserfeedback');
} else {
  log('No permission to inject script:', widgetUrl);
  data.gtmOnFailure();
}


