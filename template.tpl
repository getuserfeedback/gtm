    assertThat(queuedCommands[0].kind).isEqualTo('setColorScheme');
    assertThat(queuedCommands[0].scheme).isEqualTo('system');

- name: Automatic (Sync with Host) mode queues theme source and default
  code: |-
    const queuedCommands = [];
    mock('createQueue', function(queueName) {
      return function(command) {
        queuedCommands.push(command);
      };
    });
    
    runCode({
      apiKey: 'test123',
      themeMode: 'host',
      themeAttr: 'data-theme',
      themeDefault: 'dark'
    });
    
    assertThat(queuedCommands.length).isEqualTo(2);
    assertThat(queuedCommands[0].kind).isEqualTo('setThemeSourceAttr');
    assertThat(queuedCommands[0].attr).isEqualTo('data-theme');
    assertThat(queuedCommands[1].kind).isEqualTo('setThemeDefault');
    assertThat(queuedCommands[1].theme).isEqualTo('dark');

