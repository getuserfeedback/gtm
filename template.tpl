# =============================================================================
# GTM TEMPLATE TEST SUITE
# =============================================================================
# Comprehensive tests for scope-based consent model with automatic and manual modes.
# All tests verify that GTM Consent Mode signals correctly map to widget scopes.
#
# Test Coverage:
# - Script injection and basic functionality (8 tests)
# - Theme mode configurations (17 tests)
# - Automatic consent mode with GTM integration (10 tests)
# - Manual consent mode with custom mappings (11 tests)
# - Edge cases and error handling (2 tests)
#
# Total: 37+ tests

# =============================================================================
# P0: CRITICAL TESTS - Core Functionality
# =============================================================================

# -----------------------------------------------------------------------------
# Basic Script Injection
# -----------------------------------------------------------------------------
- name: Script URL is correctly constructed from API key
  code: |-
    let capturedUrl;
    mock('injectScript', function(url, onSuccess, onFailure) {
      capturedUrl = url;
      onSuccess();
    });
    
    // Complete isolated mock - no real config leakage
    
    runCode({
      apiKey: 'test-api-key-123',
      themeMode: 'light',
      themeModeVariable: undefined,
      themeAttr: undefined,
      themeDefault: undefined
    });
    
    assertThat(capturedUrl).isEqualTo('https://cdn.getuserfeedback.com/widget/v1/test-api-key-123/widget.js');

- name: Script injection is called
  code: |-

    
    runCode({
      apiKey: 'test123',
      themeMode: 'light',
      themeModeVariable: undefined,
      themeAttr: undefined,
      themeDefault: undefined
    });
    
    assertApi('injectScript').wasCalled();

# -----------------------------------------------------------------------------
# Fixed Theme Modes
# -----------------------------------------------------------------------------
- name: Always Light mode queues setColorScheme with light
  code: |-
    const queuedCommands = [];
    mock('createQueue', function(queueName) {
      return function(command) {
        queuedCommands.push(command);
      };
    });
    
    runCode({
      apiKey: 'test123',
      themeMode: 'light',
      themeModeVariable: undefined,
      themeAttr: undefined,
      themeDefault: undefined
    });
    
    // Debug: log what we got
    assertThat(queuedCommands.length).isGreaterThan(0);
    assertThat(queuedCommands[0].kind).isDefined();
    assertThat(queuedCommands.length).isEqualTo(1);
    assertThat(queuedCommands[0].kind).isEqualTo('setColorScheme');
    assertThat(queuedCommands[0].scheme).isEqualTo('light');

- name: Always Dark mode queues setColorScheme with dark
  code: |-
    const queuedCommands = [];
    mock('createQueue', function(queueName) {
      return function(command) {
        queuedCommands.push(command);
      };
    });
    
    runCode({
      apiKey: 'test123',
      themeMode: 'dark',
      themeModeVariable: undefined,
      themeAttr: undefined,
      themeDefault: undefined
    });
    
    assertThat(queuedCommands.length).isEqualTo(1);
    assertThat(queuedCommands[0].kind).isEqualTo('setColorScheme');
    assertThat(queuedCommands[0].scheme).isEqualTo('dark');

- name: Follow System Preference mode queues setColorScheme with system
  code: |-
